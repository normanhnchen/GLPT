{   
    "file_paths": {
        "scene": "src/assets/dragon_scene.glb",
        "hdri": "src/assets/day_sky_hdri.exr",
        
        "vert": "src/shaders/render.vs",
        "frag": "src/shaders/render.fs",
        "comp": "src/shaders/render.comp"
    },
    "screen": {
        "width": 1920,
        "height": 1080,
        "vsync": true,
        "fps_cap": 240
    },
    "camera": {
        "_yaw": 90,
        "_pitch": 0,
        "movement_speed": 5,
        "mouse_sensitivity": 0.1,
        "fov": 45,
        "pos": [0, 0, 0],
        "_front": [0, 0, -1],
        "_up": [0, 1, 0],
        "_world_up": [0, 1, 0]
    },
    "path_tracing": {
        "max_depth": 8,
        "max_samples": 4096
    },
    "post_processing": {
        "blur": 1.0,
        "aperture": 0.0,
        "focus_dist": 10,
        "auto_focus": 0,
        "exposure": 3.0,
        "tonemap": "AgX",
        "hdri_exposure": 1.0
    }
}